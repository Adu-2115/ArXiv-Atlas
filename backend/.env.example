GROQ_API_KEY=
# Strong model — used for ranking judgment and cross-paper synthesis, where
# actual reasoning quality matters most.
GROQ_MODEL=llama-3.3-70b-versatile
# Cheap/fast model — used for query expansion and per-paper extraction,
# which are narrow tasks that don't need 70B-level reasoning. This is where
# most of your token volume comes from (extraction runs once per paper).
GROQ_QUERY_EXPANSION_MODEL=llama-3.1-8b-instant
GROQ_EXTRACTION_MODEL=llama-3.1-8b-instant

MAX_CANDIDATES=60
MAX_QUERY_EXPANSIONS=4
CROSS_ENCODER_TOP_K=15
FINAL_PAPER_COUNT=12
MIN_RELEVANCE_SCORE=40
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Final ranking score blend weights (should sum to 1.0)
RELEVANCE_WEIGHT=0.55
CITATION_WEIGHT=0.3
RECENCY_WEIGHT=0.15

# MMR diversity reranking: 1.0 = pure relevance, lower = more diversity
MMR_LAMBDA=0.7
EMBEDDING_MODEL=all-MiniLM-L6-v2

FRONTEND_ORIGIN=http://localhost:3000
